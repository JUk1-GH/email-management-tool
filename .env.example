# Legacy Nextcloud example kept only for historical reference.
# Current production stack uses jemail-app + jemail-backend instead.
NEXTCLOUD_PORT=8080

MYSQL_DATABASE=nextcloud
MYSQL_USER=nextcloud
MYSQL_PASSWORD=change-this-db-password
MYSQL_ROOT_PASSWORD=change-this-root-password

NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=change-this-admin-password

# Use your public server host or IP.
NEXTCLOUD_TRUSTED_DOMAINS=localhost 127.0.0.1 mail.example.com
OVERWRITEHOST=mail.example.com
OVERWRITEPROTOCOL=https
